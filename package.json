{
  "name": "the-breakery",
  "private": true,
  "version": "0.1.0",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test --concurrency=1",
    "test:watch": "turbo run test:watch",
    "e2e": "playwright test",
    "e2e:list": "playwright test --list",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:start": "echo \"Docker retiré 2026-05-14 — DB = Supabase cloud V3 (cf CLAUDE.md §DB workflow)\" && exit 1",
    "db:stop": "echo \"Docker retiré 2026-05-14 — DB = Supabase cloud V3 (cf CLAUDE.md §DB workflow)\" && exit 1",
    "db:reset": "echo \"Docker retiré 2026-05-14 — DB = Supabase cloud V3 (cf CLAUDE.md §DB workflow)\" && exit 1",
    "db:types": "supabase gen types typescript --db-url \"$SUPABASE_DB_URL\" --schema public > packages/supabase/src/types.generated.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "eslint": "^8.57.1",
    "eslint-import-resolver-typescript": "^3.7.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-react": "^7.37.3",
    "eslint-plugin-react-hooks": "^5.1.0",
    "prettier": "^3.4.2",
    "turbo": "^2.10.2",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.18.2"
  },
  "pnpm": {
    "overrides": {
      "serialize-javascript@<7.0.5": ">=7.0.5",
      "fast-uri@<3.1.2": ">=3.1.2",
      "@babel/plugin-transform-modules-systemjs@<7.29.4": ">=7.29.4",
      "esbuild@<0.25.0": ">=0.25.0",
      "brace-expansion@>=5.0.0 <5.0.6": ">=5.0.6",
      "ws@<8.20.1": ">=8.20.1",
      "vite@<6.4.2": ">=6.4.2 <7"
    }
  }
}
